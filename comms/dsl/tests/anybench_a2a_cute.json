          "binary_args": "",
          "env_vars": {
            "A2A_CAPS": "32",
            "DISABLE_OILFS": "1",
            "TRITON_CACHE_DIR": "/tmp/triton_cache"
          },
          "iteration": 1,
          "timeout": 1800,
          "ppn": 4,
          "parser": {
            "command": "python3 $ANYBENCH_PARSER",
            "parser_path": "comms/dsl/tests/anybench_a2a_cute_parser.py",
            "timeout": 120
          }
        }
      ]
    }
  }
}
